# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # NUNCA expor no client-side

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── WHATSAPP PROVIDER ────────────────────────────────────────────────────────
# Valores: "evolution" (padrão) | "meta"
WHATSAPP_PROVIDER="evolution"

# Evolution API (provider=evolution)
EVOLUTION_API_URL="https://evolution.seudominio.com"
EVOLUTION_API_KEY="sua-api-key-evolution"
EVOLUTION_DEFAULT_INSTANCE="Xpag Atendimento"

# Meta Cloud API Oficial (provider=meta)
META_WA_TOKEN="EAAxxxxx"                 # System User Token
META_WA_PHONE_NUMBER_ID="123456789"      # ID do número no painel Meta
META_WA_VERSION="v20.0"                  # Versão da Graph API
META_WA_VERIFY_TOKEN="seu-verify-token"  # Token para verificação de webhook

# ─── OPENAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── XPAG — CONFIGURAÇÕES DE NEGÓCIO ─────────────────────────────────────────
XPAG_CONSULTANT_WHATSAPP="5581999990000"    # WhatsApp do consultor Felipe
XPAG_CONSULTANT_INSTANCE="Xpag Atendimento" # Instância para notificação

# ─── CRON JOBS (segurança) ────────────────────────────────────────────────────
# Vercel Cron envia: Authorization: Bearer ${CRON_SECRET}
CRON_SECRET="seu-segredo-cron-aqui"

# ─── IMPORTANTE ───────────────────────────────────────────────────────────────
# Nunca faça commit do arquivo .env.local com valores reais!
# Copie este arquivo: cp .env.example .env.local
